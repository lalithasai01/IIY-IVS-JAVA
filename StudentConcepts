import java.util.*;
class Student implements Comparable<Student>{
int id;String name;int age;
Student(int id,String name,int age){this.id=id;this.name=name;this.age=age;}
public int compareTo(Student s){return this.age-s.age;}
public String toString(){return id+" "+name+" "+age;}
}
class NameComparator implements Comparator<Student>{
public int compare(Student s1,Student s2){return s1.name.compareTo(s2.name);}
}
public class StudentConcepts{
public static void main(String[] args){
ArrayList<Student> students=new ArrayList<>();
students.add(new Student(1,"Uday",20));
students.add(new Student(2,"Ravi",22));
students.add(new Student(3,"Anjali",18));
for(Student s:students){System.out.println(s);}
Iterator<Student> it=students.iterator();
while(it.hasNext()){System.out.println(it.next());}
Collections.sort(students);
for(Student s:students){System.out.println(s);}
Collections.sort(students,new NameComparator());
for(Student s:students){System.out.println(s);}
}
}